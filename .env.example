# ─────────────────────────────────────────────────────────────────────────────
# Velora — Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Velora
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-min-32-chars-here-change-this

# ── CROO Protocol (REQUIRED) ─────────────────────────────────────────────────
# Get these from https://agent.croo.network after registering your agent
CROO_SDK_KEY=croo_sk_your_key_here
CROO_AGENT_ID=your-agent-id-here
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
BASE_RPC_URL=https://mainnet.base.org

# ── AI Providers (at least ONE required) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...
OLLAMA_BASE_URL=http://localhost:11434

# AI configuration
AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_CHAIN=["groq","anthropic","gemini","openrouter","ollama"]
AI_DEFAULT_MODEL=gpt-4o
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.2

# ── Web Search (for Research skill) ──────────────────────────────────────────
SERPER_API_KEY=your-serper-key

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://velora:velora@postgres:5432/velora
POSTGRES_PASSWORD=velora_secure_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ── Security ──────────────────────────────────────────────────────────────────
VELORA_API_KEY=your-internal-api-key-optional

# ── CROO Behavior ─────────────────────────────────────────────────────────────
NEGOTIATION_AUTO_ACCEPT=true
MAX_CONCURRENT_ORDERS=10
TASK_TIMEOUT_SECONDS=300
DELIVERY_RETRY_ATTEMPTS=3
